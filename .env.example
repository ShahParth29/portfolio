# ═══════════════════════════════════════════════════════════════
# Parth Edits — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your real values.
# NEVER commit .env with real credentials to git!
# ═══════════════════════════════════════════════════════════════

# Database (default SQLite for local dev)
DATABASE_URL=sqlite:///./portfolio.db

# JWT Secret — generate a random 64-char string for production
# Example: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=generate-a-random-64-char-string-here

# Admin credentials for the dashboard
ADMIN_USERNAME=your-admin-username
ADMIN_PASSWORD=your-strong-password

# Gmail SMTP for contact form notifications (optional)
# Use a Gmail App Password, NOT your real Gmail password
# https://support.google.com/accounts/answer/185833
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# CORS — comma-separated allowed origins for production
# Example: https://your-site.vercel.app,https://your-domain.com
CORS_ORIGINS=*
