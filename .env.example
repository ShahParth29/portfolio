# ═══════════════════════════════════════════════════════════════
# NextFrame Studios — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your real values.
# NEVER commit .env with real credentials to git!
# ═══════════════════════════════════════════════════════════════

# Database (default SQLite for local dev)
DATABASE_URL=sqlite:///./portfolio.db

# JWT Secret — generate a random 64-char string for production
# Example: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=generate-a-random-64-char-string-here

# Admin credentials for the dashboard
ADMIN_USERNAME=your-admin-username
ADMIN_PASSWORD=your-strong-password

# Gmail SMTP for contact form notifications (optional)
# Use a Gmail App Password, NOT your real Gmail password
# https://support.google.com/accounts/answer/185833
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# Storage backend: "local", "cloudinary", or "s3"
# "local" saves files to frontend/uploads/ directory
# "cloudinary" uploads files to Cloudinary CDN
# "s3" uploads files to S3-compatible cloud storage (AWS S3, Cloudflare R2, Backblaze B2)
STORAGE_BACKEND=local

# Cloudinary (required when STORAGE_BACKEND=cloudinary)
# Sign up at https://cloudinary.com (free tier: 25GB storage + 25GB bandwidth/month)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# S3 / Cloudflare R2 / Backblaze B2 (required when STORAGE_BACKEND=s3)
# For Cloudflare R2: Endpoint is https://<account_id>.r2.cloudflarestorage.com
# For Backblaze B2: Endpoint is https://s3.<region>.backblazeb2.com
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_ENDPOINT_URL=
S3_REGION_NAME=
S3_PUBLIC_URL=

# CORS — comma-separated allowed origins for production
# Example: https://your-site.vercel.app,https://your-domain.com
CORS_ORIGINS=*
